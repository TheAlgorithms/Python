 import random


def half_life_sort(collection: list[int], seed: int | None = None) -> list[int]:
    """
    A probabilistic sorting algorithm inspired by radioactive isotope decay.

    Instead of guaranteeing a swap when two adjacent elements are out of order,
    this algorithm gives the "inversion" a 50% probability of decaying (swapping).
    The algorithm continues passing over the array until no inversions remain
    and the collection is perfectly "stable" (sorted).

    Args:
        collection: A list of integers to be sorted.
        seed: Optional integer seed for random number generation to ensure
              reproducibility in doctests.

    Returns:
        A new list containing the sorted elements.

    Examples:
        >>> half_life_sort([3, 1, 2], seed=42)
        [1, 2, 3]
        >>> half_life_sort([5, 4, 3, 2, 1], seed=10)
        [1, 2, 3, 4, 5]
        >>> half_life_sort([10, -1, 4, 2], seed=99)
        [-1, 2, 4, 10]
        >>> half_life_sort([], seed=1)
        []
        >>> half_life_sort([1], seed=1)
        [1]
    """
    if seed is not None:
        random.seed(seed)

    if len(collection) <= 1:
        return collection

    # Create a copy to avoid mutating the original array
    arr = collection.copy()
    is_sorted = False

    while not is_sorted:
        is_sorted = True
        for i in range(len(arr) - 1):
            # Check for an "unstable isotope" (an inversion)
            if arr[i] > arr[i + 1]:
                is_sorted = False
                # 50% chance for the inversion to "decay" into a stable state
                if random.choice([True, False]):
                    arr[i], arr[i + 1] = arr[i + 1], arr[i]

    return arr


